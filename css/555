:root{--bg:#070a0f;--panel:#111823;--panel2:#151d29;--line:#2b3342;--gold:#d4af37;--gold2:#b98d24;--text:#f4f6fb;--muted:#9ca6b5;--green:#51d88a;--red:#ff6666}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,Segoe UI,Arial,sans-serif}.site-header{position:fixed;z-index:10;top:0;left:0;right:0;height:76px;display:flex;align-items:center;justify-content:space-between;padding:0 32px;background:rgba(5,7,10,.82);border-bottom:1px solid rgba(212,175,55,.2);backdrop-filter:blur(12px)}.site-header.solid{position:sticky}.brand{display:flex;align-items:center;gap:14px;color:var(--text);text-decoration:none}.badge{border:1px solid var(--gold);background:var(--gold);color:#080a0d;padding:7px 12px;border-radius:4px;font-weight:900;letter-spacing:2px}.brand strong{display:block;text-transform:uppercase;letter-spacing:1px}.brand small{display:block;color:var(--gold);text-transform:uppercase;font-size:11px;letter-spacing:1.4px}.site-header nav{display:flex;align-items:center;gap:12px}.site-header nav a{color:var(--muted);text-decoration:none}.btn{display:inline-flex;align-items:center;justify-content:center;border:1px solid var(--gold);background:linear-gradient(180deg,var(--gold),var(--gold2));color:#080a0d;text-transform:uppercase;font-weight:900;letter-spacing:1px;border-radius:6px;padding:14px 22px;text-decoration:none;cursor:pointer}.btn.small{padding:10px 16px;font-size:13px}.btn.ghost{background:transparent;color:var(--gold)}.hero{min-height:670px;position:relative;background:url('../assets/vice-hero.png') center/cover no-repeat;display:grid;place-items:center;padding:120px 24px 48px}.hero.public:after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(7,10,15,.95),rgba(7,10,15,.62),rgba(7,10,15,.9))}.overlay{position:absolute;inset:0;background:radial-gradient(circle at center,transparent,rgba(0,0,0,.55))}.hero-content{position:relative;z-index:2;max-width:860px;text-align:center}.eyebrow{display:inline-block;border:1px solid rgba(212,175,55,.35);border-radius:999px;padding:8px 18px;color:var(--gold);text-transform:uppercase;letter-spacing:3px;font-size:12px;background:rgba(0,0,0,.35)}h1{font-size:clamp(42px,7vw,78px);line-height:.95;margin:22px 0 14px}h1 span{color:var(--gold)}.lead{color:#d8dee8;font-size:18px;line-height:1.6}.motto{color:var(--gold);font-weight:900;text-transform:uppercase;letter-spacing:2px}.actions{display:flex;gap:14px;justify-content:center;margin-top:28px;flex-wrap:wrap}.container{max-width:1240px;margin:0 auto;padding:0 24px}.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:-58px;position:relative;z-index:3}.stats-grid article{background:linear-gradient(180deg,var(--panel2),var(--panel));border:1px solid rgba(212,175,55,.35);border-radius:8px;padding:24px;text-align:center;box-shadow:0 16px 40px rgba(0,0,0,.35)}.stats-grid strong{display:block;color:#fff;font-size:36px}.stats-grid span{color:var(--gold);font-size:12px;text-transform:uppercase;letter-spacing:1px}.panel{background:linear-gradient(180deg,var(--panel2),var(--panel));border:1px solid var(--line);border-radius:10px;padding:28px;margin-top:28px}.section-title{display:flex;align-items:center;justify-content:space-between}.section-title h2,.panel h2{margin:0 0 16px;text-transform:uppercase;letter-spacing:1px}.section-title span,mark{background:rgba(212,175,55,.14);color:var(--gold);border:1px solid rgba(212,175,55,.35);padding:5px 10px;border-radius:4px;text-transform:uppercase;font-size:12px}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse}th,td{padding:16px;border-bottom:1px solid var(--line);text-align:left}th{color:var(--muted);text-transform:uppercase;font-size:12px;letter-spacing:1px}.login-card{display:grid;grid-template-columns:1.2fr .8fr;gap:28px;align-items:center;background:linear-gradient(120deg,rgba(17,24,35,.95),rgba(7,10,15,.95));border:1px solid rgba(212,175,55,.35);border-radius:12px;padding:34px;margin-top:36px;margin-bottom:44px}form{display:grid;gap:14px}input{width:100%;padding:15px;border-radius:6px;border:1px solid var(--line);background:#0b1018;color:var(--text)}.form-message{min-height:20px;color:var(--muted)}footer{text-align:center;color:var(--muted);border-top:1px solid var(--line);padding:28px}.dashboard-body{background:radial-gradient(circle at top,#141b27,#070a0f 45%)}.dashboard{padding-top:30px;padding-bottom:60px}.welcome h1{font-size:44px}.muted{color:var(--muted)}.cards-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.feed{padding:0;margin:0;list-style:none}.feed li{border-bottom:1px solid var(--line);padding:14px 0}.feed li:last-child{border-bottom:0}.feed b{display:block}.feed span{display:block;color:var(--muted);font-size:14px;margin-top:4px}@media(max-width:850px){.site-header{padding:0 16px}.site-header nav a:not(.btn){display:none}.stats-grid,.cards-3,.login-card{grid-template-columns:1fr}.stats-grid{margin-top:24px}.hero{min-height:620px}.login-card{margin-left:24px;margin-right:24px}}
